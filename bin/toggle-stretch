#!/usr/bin/env bash
# toggle-stretch — enable/disable stretch reminder (fires at :45 each hour)

TIMER=stretch-reminder.timer

if systemctl --user is-active --quiet "$TIMER"; then
    systemctl --user stop "$TIMER"
    notify-send -u low -i clock "Stretch" "Reminders disabled."
else
    systemctl --user start "$TIMER"
    notify-send -u low -i clock "Stretch" "Reminders enabled — fires at :45 each hour."
fi
